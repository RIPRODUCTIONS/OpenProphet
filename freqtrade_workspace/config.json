        "use_order_book": false,
        "order_book_top": 1
    },
    "exchange": {
        "name": "coinbase",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT",
            "ETH/USDT",
            "SOL/USDT",
            "AVAX/USDT",
            "LINK/USDT",
            "DOT/USDT"
        ],
        "pair_blacklist": [],
