{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    // Required: The Prophet MCP trading tools server
    "prophet": {
      "type": "local",
      "command": ["node", "./mcp-server.js"],
      "enabled": true
    }

    // Optional: Add any other MCP servers you use below.
    // Examples:
    //
    // "playwright": {
    //   "type": "local",
    //   "command": ["npx", "@playwright/mcp@latest"],
    //   "enabled": true
    // },
    //
    // "my-other-server": {
    //   "type": "local",
    //   "command": ["node", "/path/to/my-mcp-server.js"],
    //   "enabled": true
    // }
  }
}
