# Alpaca API Configuration
ALPACA_ENDPOINT=https://paper-api.alpaca.markets
ALPACA_PUBLIC_KEY=your_alpaca_public_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# Gemini API (optional - for AI news cleaning)
GEMINI_API_KEY=your_gemini_api_key

# Agent Dashboard Configuration (optional)
AGENT_PORT=3737                        # Dashboard port (default: 3737)
AGENT_AUTH_TOKEN=                       # Set a token to require auth on all API routes
TRADING_BOT_PORT=4534                   # Go backend port (default: 4534)
TRADING_BOT_URL=http://localhost:4534   # Go backend URL (default: auto from port)

# ─── Crypto Exchange Configuration (ccxt) ─────────────────────────────────
# Only configure exchanges you want to use. Sandbox defaults to true for safety.

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_SANDBOX=true                   # Set to false for live trading

# Coinbase (Advanced Trade / Pro)
COINBASE_API_KEY=
COINBASE_SECRET=
COINBASE_PASSPHRASE=
COINBASE_SANDBOX=true                  # Set to false for live trading

# Kraken
KRAKEN_API_KEY=
KRAKEN_SECRET=
KRAKEN_SANDBOX=true                    # Set to false for live trading

# ─── Alert Notifications ─────────────────────────────────────────────────
# Configure channels to receive trade alerts, risk warnings, and system errors.
# Leave blank to disable a channel. At least one channel recommended for monitoring.

ALERTS_ENABLED=true                    # Master switch for all alerts

# Telegram Bot (primary) — create via @BotFather, get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook — create in Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Generic Webhook — receives signed JSON POSTs (HMAC-SHA256 in X-Signature header)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
